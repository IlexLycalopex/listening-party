---
import SiteNav from '../components/SiteNav.astro';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Listening Party',
  description = '52 weeks. 2 brothers. One album from every year 2000–2025.',
  ogImage,
} = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  {ogImage && <meta property="og:image" content={ogImage} />}
  <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  <link rel="sitemap" href={`${base}/sitemap-index.xml`} />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&display=swap" rel="stylesheet">
</head>
<body>
  <SiteNav />
  <slot />
  <script>
    // Site-wide modal handling via event delegation: any element with
    // [data-modal] opens the .notes-modal with that id; [data-close-modal]
    // or Escape closes it.
    function openModal(id: string) {
      const modal = document.getElementById(id) as HTMLElement | null;
      if (!modal) return;
      modal.hidden = false;
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      (modal.querySelector('.notes-modal__close') as HTMLElement)?.focus();
    }

    function closeModal(modal: HTMLElement) {
      modal.hidden = true;
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;

      // Open via trigger button
      const trigger = target.closest('[data-modal]') as HTMLElement | null;
      if (trigger?.dataset.modal) {
        openModal(trigger.dataset.modal);
        return;
      }

      // Close via backdrop or close button
      if (target.closest('[data-close-modal]')) {
        const modal = target.closest('.notes-modal') as HTMLElement | null;
        if (modal) closeModal(modal);
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        const open = document.querySelector('.notes-modal:not([hidden])') as HTMLElement | null;
        if (open) closeModal(open);
      }
    });
  </script>
</body>
</html>
<style is:global>
  @import '../styles/global.css';
</style>
