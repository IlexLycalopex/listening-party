---
import { loadContributors } from '../lib/data';
import yaml from 'js-yaml';
import { readFileSync, existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import { join, dirname } from 'node:path';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const relPath = join(dirname(fileURLToPath(import.meta.url)), '..', 'data', 'seasons.yaml');
const seasonsPath = existsSync(relPath) ? relPath : join(process.cwd(), 'src', 'data', 'seasons.yaml');
const seasonsRaw = readFileSync(seasonsPath, 'utf8');
const seasons: Array<{ id: string; status: string }> = yaml.load(seasonsRaw) as any;
const activeSeasons = seasons.filter(s => s.status === 'active');

const contributors = loadContributors();
const pathname = Astro.url.pathname;
---

<nav class="site-nav">
  <div class="container site-nav__inner">

    <!-- Logo -->
    <a href={`${base}/`} class="site-nav__logo">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6">
        <circle cx="12" cy="12" r="9"/>
        <circle cx="12" cy="12" r="3.5"/>
        <circle cx="12" cy="12" r="1" fill="currentColor" stroke="none"/>
      </svg>
      <span>Listening Party</span>
    </a>

    <!-- Right-side links -->
    <div class="site-nav__links">

      <!-- Season tabs -->
      {activeSeasons.map(s => (
        <a
          href={`${base}/${s.id}/`}
          class={`site-nav__pill${pathname.includes(`/${s.id}`) ? ' active' : ''}`}
        >
          {s.id}
        </a>
      ))}

      <span class="site-nav__sep"></span>

      <!-- Contributors (direct links, coloured dots) -->
      {contributors.map(c => (
        <a
          href={`${base}/contributors/${c.id}/`}
          class={`site-nav__contrib${pathname.includes(`/contributors/${c.id}`) ? ' active' : ''}`}
          title={c.name}
        >
          <span class="site-nav__contrib-dot" style={`background:${c.color}`}></span>
          <span class="site-nav__contrib-name">{c.name}</span>
        </a>
      ))}

      <span class="site-nav__sep"></span>

      <!-- Artists -->
      <a
        href={`${base}/artists/`}
        class={`site-nav__pill${pathname.includes('/artists') ? ' active' : ''}`}
      >
        Artists
      </a>

    </div>
  </div>
</nav>
