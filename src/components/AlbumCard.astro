---
export interface Props {
  week: number;
  year_slot: number;
  contributor: string;
  album: string;
  artist: string;
  status: 'completed' | 'upcoming';
  artwork_url?: string;
  links?: { wikipedia?: string; spotify?: string; youtube?: string };
  notes?: string;
  contributorColor?: string;
  contributorName?: string;
  isNowPlaying?: boolean;
}

const {
  week,
  contributor,
  album,
  artist,
  status,
  artwork_url,
  links,
  notes,
  contributorColor = '#888',
  contributorName = contributor,
  isNowPlaying = false,
} = Astro.props;

const isUpcoming = status === 'upcoming';
const hasNotes = !isUpcoming && Boolean(notes?.trim());
const modalId = `notes-wk${week}`;

// Auto-generate search links when not manually supplied
const q = encodeURIComponent(`${artist} ${album}`);
const wikiUrl    = links?.wikipedia || `https://en.wikipedia.org/w/index.php?search=${q}`;
const youtubeUrl = links?.youtube   || `https://music.youtube.com/search?q=${q}`;
const spotifyUrl = links?.spotify   || `https://open.spotify.com/search/${q}`;
---

<article
  class={`album-card${isUpcoming ? ' album-card--upcoming' : ''}${isNowPlaying ? ' album-card--now-playing' : ''}`}
  id={isNowPlaying ? 'now-playing' : undefined}
  style={`--contrib-color: ${contributorColor}`}
>
  {isNowPlaying && <div class="album-card__np-badge">▶ NOW PLAYING</div>}

  <div class="album-card__artwork">
    {!isUpcoming && artwork_url
      ? <img src={artwork_url} alt={`${album} by ${artist}`} loading="lazy" />
      : <div class="album-card__artwork-placeholder">
          {isUpcoming
            ? <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
            : <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
                <circle cx="12" cy="12" r="9" />
                <circle cx="12" cy="12" r="3" />
                <path d="M12 3v3M12 18v3M3 12h3M18 12h3" stroke-linecap="round"/>
              </svg>
          }
        </div>
    }
    <span class="album-card__week">Wk {week}</span>
  </div>

  <div class="album-card__body">
    <div class="album-card__contributor">
      <span class="album-card__contributor-dot" style={`background:${contributorColor}`}></span>
      {contributorName}
    </div>

    {isUpcoming
      ? <div class="album-card__locked-label">Upcoming</div>
      : <>
          <div class="album-card__title">{album}</div>
          <div class="album-card__artist">{artist}</div>
        </>
    }

    {!isUpcoming &&
      <div class="album-card__links">
        {hasNotes && (
          <button
            class="album-card__link album-card__notes-trigger"
            data-modal={modalId}
            title="Read notes"
            aria-label="Read notes"
            type="button"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
              <line x1="10" y1="9" x2="8" y2="9"/>
            </svg>
          </button>
        )}
        <a class="album-card__link" href={wikiUrl} target="_blank" rel="noopener" title="Wikipedia">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
        </a>
        <a class="album-card__link" href={spotifyUrl} target="_blank" rel="noopener" title="Spotify">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm4.586 14.424a.623.623 0 01-.857.207c-2.348-1.435-5.304-1.76-8.785-.964a.623.623 0 01-.277-1.215c3.809-.87 7.077-.496 9.712 1.115a.624.624 0 01.207.857zm1.223-2.722a.78.78 0 01-1.072.257c-2.687-1.652-6.785-2.131-9.965-1.166a.78.78 0 01-.973-.519.781.781 0 01.52-.972c3.632-1.102 8.147-.568 11.233 1.328a.78.78 0 01.257 1.072zm.105-2.835c-3.223-1.914-8.54-2.09-11.618-1.156a.937.937 0 11-.543-1.794c3.533-1.072 9.404-.865 13.115 1.338a.937.937 0 01-.954 1.612z"/></svg>
        </a>
        <a class="album-card__link" href={youtubeUrl} target="_blank" rel="noopener" title="YouTube Music">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/></svg>
        </a>
      </div>
    }
  </div>
</article>

{hasNotes && (
  <div class="notes-modal" id={modalId} hidden aria-hidden="true">
    <div class="notes-modal__backdrop" data-close-modal></div>
    <div class="notes-modal__box" role="dialog" aria-modal="true" aria-label={`Notes for ${album}`}>
      <div class="notes-modal__header">
        <div class="notes-modal__meta">
          <div class="notes-modal__album">{album}</div>
          <div class="notes-modal__byline">
            <span class="notes-modal__dot" style={`background:${contributorColor}`}></span>
            {contributorName} · {artist}
          </div>
        </div>
        <button class="notes-modal__close" data-close-modal aria-label="Close notes" type="button">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
      <p class="notes-modal__body">{notes}</p>
    </div>
  </div>
)}

<script>
  // Event delegation — runs once, handles all note modals on the page
  if (!(window as any).__notesModalReady) {
    (window as any).__notesModalReady = true;

    function openModal(id: string) {
      const modal = document.getElementById(id) as HTMLElement | null;
      if (!modal) return;
      modal.hidden = false;
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      (modal.querySelector('.notes-modal__close') as HTMLElement)?.focus();
    }

    function closeModal(modal: HTMLElement) {
      modal.hidden = true;
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;

      // Open via trigger button
      const trigger = target.closest('[data-modal]') as HTMLElement | null;
      if (trigger?.dataset.modal) {
        openModal(trigger.dataset.modal);
        return;
      }

      // Close via backdrop or close button
      if (target.closest('[data-close-modal]')) {
        const modal = target.closest('.notes-modal') as HTMLElement | null;
        if (modal) closeModal(modal);
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        const open = document.querySelector('.notes-modal:not([hidden])') as HTMLElement | null;
        if (open) closeModal(open);
      }
    });
  }
</script>
