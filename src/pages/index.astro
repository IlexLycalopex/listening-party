---
// Render the latest active season directly — no redirect needed
import { readFileSync, existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import { join, dirname } from 'node:path';
import yaml from 'js-yaml';
import { loadContributors, loadSeason, getContribMap } from '../lib/data';
import Base from '../layouts/Base.astro';
import AlbumCard from '../components/AlbumCard.astro';
import ProgressBar from '../components/ProgressBar.astro';

const relPath = join(dirname(fileURLToPath(import.meta.url)), '..', 'data', 'seasons.yaml');
const seasonsPath = existsSync(relPath) ? relPath : join(process.cwd(), 'src', 'data', 'seasons.yaml');
const seasonsRaw = readFileSync(seasonsPath, 'utf8');
const seasons: Array<{ id: string; status: string }> = yaml.load(seasonsRaw) as any;
const latestId = [...seasons].filter(s => s.status === 'active').pop()?.id ?? '2026';

const contributors = loadContributors();
const season = loadSeason(latestId);
const contribMap = getContribMap(contributors);

const completed  = season.selections.filter(s => s.status === 'completed');
const upcoming   = season.selections.filter(s => s.status === 'upcoming');
const completedCount = completed.length;
const totalWeeks = season.total_weeks;

// The card with the highest week number among completed = "now playing"
const nowPlayingWeek = completed.length > 0 ? Math.max(...completed.map(s => s.week)) : -1;

const activeContribIds = new Set(season.selections.map(s => s.contributor));
const activeContribs = contributors.filter(c => activeContribIds.has(c.id));

// Group completed picks by year_slot
const byYear = new Map<number, typeof season.selections>();
for (const sel of completed) {
  if (!byYear.has(sel.year_slot)) byYear.set(sel.year_slot, []);
  byYear.get(sel.year_slot)!.push(sel);
}
const sortedYears = [...byYear.keys()].sort((a, b) => a - b);
---

<Base title={`${season.title} | Listening Party`} description={season.description}>
  <header class="hero">
    <div class="container">
      <p class="hero__eyebrow">Season {latestId}</p>
      <h1 class="hero__title">{season.title}</h1>
      <p class="hero__description">{season.description}</p>
      <div class="hero__meta">
        {activeContribs.map(c => (
          <a href={`${import.meta.env.BASE_URL}contributors/${c.id}/`} class="contributor-badge" style="text-decoration:none">
            <span class="contributor-badge__dot" style={`background:${c.color}`}></span>
            {c.name}
          </a>
        ))}
        {nowPlayingWeek > 0 && (
          <a href="#now-playing" class="hero__jump-btn">
            <svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            Jump to current
          </a>
        )}
      </div>
    </div>
  </header>

  <ProgressBar completed={completedCount} total={totalWeeks} />

  <main class="seasons-grid">
    <div class="container">
      {sortedYears.map(year => {
        const picks = byYear.get(year)!;
        return (
          <section class="year-section">
            <h2 class="year-heading">{year}</h2>
            <div class="year-cards">
              {picks.map(pick => {
                const contrib = contribMap[pick.contributor];
                return (
                  <AlbumCard
                    week={pick.week}
                    year_slot={pick.year_slot}
                    contributor={pick.contributor}
                    album={pick.album}
                    artist={pick.artist}
                    status={pick.status}
                    artwork_url={pick.artwork_url}
                    links={pick.links}
                    notes={pick.notes}
                    contributorColor={contrib?.color ?? '#888'}
                    contributorName={contrib?.name ?? pick.contributor}
                    isNowPlaying={pick.week === nowPlayingWeek}
                  />
                );
              })}
            </div>
          </section>
        );
      })}

      {upcoming.length > 0 && (
        <section class="year-section upcoming-section">
          <h2 class="year-heading">
            Upcoming
            <span class="year-heading__count">{upcoming.length} weeks remaining</span>
          </h2>
          <div class="year-cards">
            {upcoming.map(pick => {
              const contrib = contribMap[pick.contributor];
              return (
                <AlbumCard
                  week={pick.week}
                  year_slot={pick.year_slot}
                  contributor={pick.contributor}
                  album={pick.album}
                  artist={pick.artist}
                  status="upcoming"
                  contributorColor={contrib?.color ?? '#888'}
                  contributorName={contrib?.name ?? pick.contributor}
                />
              );
            })}
          </div>
        </section>
      )}
    </div>
  </main>

  <footer class="site-footer">
    <div class="container" style="display:flex;justify-content:space-between;flex-wrap:wrap;gap:8px;width:100%;">
      <span>Listening Party {latestId}</span>
      <span style="color:var(--text-faint);">Edit <code style="font-family:var(--mono)">src/data/selections/{latestId}.yaml</code> each week</span>
    </div>
  </footer>
</Base>
