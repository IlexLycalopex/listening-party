---
// Redirect to the latest active season
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import yaml from 'js-yaml';

const seasonsRaw = readFileSync(join(process.cwd(), 'src', 'data', 'seasons.yaml'), 'utf8');
const seasons: Array<{ id: string; status: string }> = yaml.load(seasonsRaw) as any;
const latest = [...seasons].filter(s => s.status === 'active').pop();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

return Astro.redirect(`${base}/${latest?.id ?? '2026'}/`);
---
