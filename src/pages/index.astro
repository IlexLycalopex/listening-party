---
// Render the latest active season directly — no redirect needed
import { loadSeasonsIndex } from '../lib/data';
import SeasonView from '../components/SeasonView.astro';

const seasons = loadSeasonsIndex();
const latest = seasons.filter(s => s.status === 'active').pop() ?? seasons[seasons.length - 1];
---

<SeasonView seasonId={latest.id} />
