---
import { loadAllSelections, loadContributors, getAllArtists, getContribMap, slugify, type Selection } from '../../lib/data';
import Base from '../../layouts/Base.astro';
import AlbumLinks from '../../components/AlbumLinks.astro';

const allSelections = loadAllSelections();
const contributors  = loadContributors();
const contribMap    = getContribMap(contributors);
const completed     = allSelections.filter(s => s.status === 'completed' && s.artist);

// Group completed picks by artist
const picksByArtist = new Map<string, Selection[]>();
for (const s of completed) {
  if (!picksByArtist.has(s.artist)) picksByArtist.set(s.artist, []);
  picksByArtist.get(s.artist)!.push(s);
}

const artists = getAllArtists(allSelections).map(name => {
  const picks = [...(picksByArtist.get(name) ?? [])].sort((a, b) => a.year_slot - b.year_slot);
  return {
    name,
    slug: slugify(name),
    picks,
    contribs: [...new Set(picks.map(p => p.contributor))],
    seasons: [...new Set(picks.map(p => p.season))].sort(),
  };
});

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="Artists | Listening Party">
  <div class="page-hero">
    <div class="container">
      <a href={`${base}/`} class="artist-detail__back">
        <svg viewBox="0 0 16 16" width="12" height="12" fill="currentColor">
          <path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Back
      </a>
      <h1 class="page-hero__title">Artists</h1>
      <p class="page-hero__sub">{artists.length} artists · all seasons</p>
    </div>
  </div>

  <main>
    <div class="container">
      <div class="artists-grid">
        {artists.map(a => (
          <button class="artist-card" type="button" data-modal={`artist-${a.slug}`} aria-haspopup="dialog">
            <span class="artist-card__name">{a.name}</span>
            <div class="artist-card__footer">
              <span class="artist-card__count">{a.picks.length} pick{a.picks.length !== 1 ? 's' : ''}</span>
              <span class="artist-card__contribs">
                {a.contribs.map(cid => {
                  const c = contribMap[cid];
                  return (
                    <span
                      class="artist-card__contrib-dot"
                      style={`background:${c?.color ?? '#888'}`}
                      title={c?.name ?? cid}
                    ></span>
                  );
                })}
              </span>
            </div>
          </button>
        ))}
      </div>
    </div>
  </main>

  {artists.map(a => (
    <div class="notes-modal" id={`artist-${a.slug}`} hidden aria-hidden="true">
      <div class="notes-modal__backdrop" data-close-modal></div>
      <div class="notes-modal__box notes-modal__box--wide" role="dialog" aria-modal="true" aria-label={`Picks by ${a.name}`}>
        <div class="notes-modal__header">
          <div class="notes-modal__meta">
            <div class="notes-modal__album">{a.name}</div>
            <div class="notes-modal__byline">
              {a.picks.length} pick{a.picks.length !== 1 ? 's' : ''} · {a.seasons.join(' · ')}
            </div>
          </div>
          <button class="notes-modal__close" data-close-modal aria-label="Close" type="button">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <line x1="18" y1="6" x2="6" y2="18"/>
              <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </button>
        </div>
        <div class="notes-modal__picks">
          {a.picks.map(pick => {
            const contrib = contribMap[pick.contributor];
            return (
              <div class="pick-row">
                <div class="pick-row__artwork">
                  {pick.artwork_url
                    ? <img src={pick.artwork_url} alt={pick.album} loading="lazy" />
                    : <div class="pick-row__artwork-placeholder">
                        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.2">
                          <circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="3"/>
                        </svg>
                      </div>
                  }
                </div>
                <div class="pick-row__info">
                  <div class="pick-row__album">{pick.album}</div>
                  <div class="pick-row__meta">
                    <span>{pick.year_slot}</span>
                    <span>·</span>
                    <span class="pick-row__contributor">
                      <span class="pick-row__dot" style={`background:${contrib?.color ?? '#888'}`}></span>
                      {contrib?.name ?? pick.contributor}
                    </span>
                    <span>·</span>
                    <a href={`${base}/${pick.season}/`} class="pick-row__season-tag">{pick.season}</a>
                  </div>
                </div>
                <div class="pick-row__links">
                  <AlbumLinks album={pick.album} artist={pick.artist} links={pick.links} />
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  ))}
</Base>
