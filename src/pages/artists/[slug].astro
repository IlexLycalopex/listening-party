---
import { loadAllSelections, loadContributors, getAllArtists, getContribMap, slugify } from '../../lib/data';
import Base from '../../layouts/Base.astro';
import AlbumLinks from '../../components/AlbumLinks.astro';

export async function getStaticPaths() {
  const allSelections = loadAllSelections();
  const artists = getAllArtists(allSelections);
  return artists.map(name => ({
    params: { slug: slugify(name) },
    props: { artistName: name },
  }));
}

const { artistName } = Astro.props;

const allSelections = loadAllSelections();
const contributors  = loadContributors();
const contribMap    = getContribMap(contributors);

const picks = allSelections
  .filter(s => s.status === 'completed' && s.artist === artistName)
  .sort((a, b) => (a.year_slot ?? 0) - (b.year_slot ?? 0));

// Unique seasons this artist appears in
const seasons = [...new Set(picks.map(p => p.season).filter(Boolean))].sort();

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title={`${artistName} | Artists | Listening Party`}>
  <div class="artist-detail">
    <div class="container">
      <a href={`${base}/artists/`} class="artist-detail__back">
        <svg viewBox="0 0 16 16" width="12" height="12" fill="currentColor">
          <path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        All artists
      </a>

      <h1 class="artist-detail__title">{artistName}</h1>

      <div class="artist-detail__meta">
        <span class="artist-detail__pick-count">{picks.length} pick{picks.length !== 1 ? 's' : ''}</span>
        {seasons.map(s => (
          <a href={`${base}/${s}/`} class="artist-detail__season-badge">{s}</a>
        ))}
      </div>

      <div class="picks-list">
        {picks.map(pick => {
          const contrib = contribMap[pick.contributor];
          return (
            <div class="pick-row">
              <div class="pick-row__artwork">
                {pick.artwork_url
                  ? <img src={pick.artwork_url} alt={pick.album} loading="lazy" />
                  : <div class="pick-row__artwork-placeholder">
                      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.2">
                        <circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="3"/>
                      </svg>
                    </div>
                }
              </div>
              <div class="pick-row__info">
                <div class="pick-row__album">{pick.album}</div>
                <div class="pick-row__meta">
                  <span>{pick.year_slot}</span>
                  <span>·</span>
                  <span class="pick-row__contributor">
                    <span class="pick-row__dot" style={`background:${contrib?.color ?? '#888'}`}></span>
                    {contrib?.name ?? pick.contributor}
                  </span>
                  {pick.season && (
                    <>
                      <span>·</span>
                      <a href={`${base}/${pick.season}/`} class="pick-row__season-tag">{pick.season}</a>
                    </>
                  )}
                </div>
              </div>
              <div class="pick-row__links">
                <AlbumLinks album={pick.album} artist={pick.artist} links={pick.links} />
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </div>
</Base>
